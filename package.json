{
  "name": "responsiver",
  "version": "0.6.0",
  "description": "Laboratoire desktop local pour auditer, corriger et valider la responsivité d’un projet web.",
  "author": "Responsiver contributors",
  "private": true,
  "main": "./out/main/index.js",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "tsx --test tests/*.test.ts",
    "test:native-host": "node --test native-host/tests/*.test.mjs",
    "test:e2e": "npm run build && node tests/electron.e2e.mjs",
    "test:e2e:onboarding": "npm run build && node tests/onboarding.e2e.mjs",
    "test:e2e:visual": "npm run build && node tests/visual-editor.e2e.mjs",
    "test:e2e:remote": "npm run build && node tests/remote-session.e2e.mjs",
    "test:e2e:localhost-link": "npm run build && node tests/localhost-association.e2e.mjs",
    "test:e2e:packaged": "node tests/electron.e2e.mjs --packaged",
    "test:project": "node tests/project.e2e.mjs",
    "package": "npm run build && electron-builder --publish never",
    "package:dir": "npm run build && electron-builder --dir",
    "sbom": "npm sbom --sbom-format spdx"
  },
  "dependencies": {
    "monaco-editor": "0.53.0",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "playwright": "^1.61.1",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  }
}
